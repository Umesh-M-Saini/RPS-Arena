<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
<nav class="navbar">
    <div class="logo">RPS Arena</div>
    <ul class="nav-links">
        <li><a href="/">Home</a></li>
        <li><a href="/play">Play</a></li>
        <!-- Auth logic here -->
        <% if(typeof isAuthenticated !== 'undefined' && isAuthenticated){ %>
            <li><a href="/profile">Profile</a></li>
            <li><a href="/auth/logout">Logout</a></li>
        <% } else { %>
            <li><a href="/login">Login</a></li>
        <% } %>
    </ul>
    <!-- The Hamburger Icon -->
    <div class="menu-toggle" id="mobile-menu">
        <span></span>
        <span></span>
        <span></span>
    </div>
</nav>    <title>RPS Arena</title>
    <link rel="stylesheet" href="/stylesheet/landing.css">
    <link rel="stylesheet" href="/stylesheet/responsive.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

</head>

<body>

    <!-- Floating Background Icons -->

    <div class="floating rock">🪨</div>
    <div class="floating paper">📄</div>
    <div class="floating scissors">✂️</div>


    <!-- Navbar -->

    <nav class="navbar">

        <div class="logo">RPS Arena</div>

        <ul class="nav-links">
            <li><a href="/">Home</a></li>
            <li><a href="/play">Play</a></li>
            <% if(isAuthenticated){ %>
                <li><a href="/profile">Profile</a></li>
                <li><a href="/auth/logout">Logout</a></li>
                <% } else { %>
                    <li><a href="/login">Login</a></li>
                    <% } %>
        </ul>

        <div class="menu-toggle" id="mobile-menu">
            <span></span>
            <span></span>
            <span></span>
        </div>

    </nav>


    <!-- Hero Section -->

    <section class="hero">

        <div class="hero-content">

            <h1>Welcome to RPS Arena</h1>

            <p>Battle players in the ultimate Rock Paper Scissors game</p>

            <div class="hero-buttons">
                <a href="/play" class="btn-primary">Play Now</a>
                <% if(!isAuthenticated){ %>
                <a href="/signup" class="btn-secondary">Create Account</a>
                <% } %>
            </div>

        </div>

    </section>



    <!-- Features -->

    <section class="features">

        <h2>Game Features</h2>

        <div class="feature-container">

            <div class="feature-card">
                <i class="fas fa-bolt"></i>
                <h3>Real-time Battles</h3>
                <p>Compete instantly with players around the world.</p>
            </div>

            <div class="feature-card">
                <i class="fas fa-trophy"></i>
                <h3>Global Leaderboard</h3>
                <p>Climb the ranks and become the RPS champion.</p>
            </div>

            <div class="feature-card">
                <i class="fas fa-user"></i>
                <h3>Player Profiles</h3>
                <p>Track your stats, wins and achievements.</p>
            </div>

        </div>

    </section>



    <!-- Call To Action -->

    <section class="cta">

        <h2>Ready to become the RPS Champion?</h2>

        <a href="/play" class="cta-btn">Start Playing</a>

    </section>



    <!-- Footer -->

    <footer>

        <div class="footer-links">

            <a href="#">About</a>
            <a href="#">Contact</a>
            <a href="#">Privacy Policy</a>

        </div>

        <div class="social">

            <i class="fab fa-discord"></i>
            <i class="fab fa-twitter"></i>
            <i class="fab fa-youtube"></i>

        </div>

        <p>© 2026 RPS Arena. All rights reserved.</p>

    </footer>


    

    <script src="/javascript/responsive.js"></script>
</body>

</html>
